generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  frequency    Frequency @default(LOW)
  lastPurchase Int
  interest     String
  createdAt    DateTime  @default(now())
}

enum Frequency {
  LOW
  MEDIUM
  HIGH
}