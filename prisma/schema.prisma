generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id            String        @id
  fullName      String?
  role          Role          @default(vendedor)
  createdAt     DateTime      @default(now())
  email         String?
  opportunities Opportunity[]
  orders        Order[]

  @@map("Profiles")
}

model Customer {
  id                Int                @id @default(autoincrement())
  fullName          String
  email             String?            @unique
  phone             String?
  city              String?
  country           String?
  registrationDate  DateTime           @default(now())
  segment           String?
  status            String             @default("activo")
  frequency         String             @default("LOW")
  lastPurchase      Int                @default(30)
  interest          String             @default("")
  assignedUserId    String?            @map("assigned_user_id")
  aiRecommendations AiRecommendation[]
  opportunities     Opportunity[]
  orders            Order[]

  @@map("Customers")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]

  @@map("Categories")
}

model Product {
  id                Int                @id @default(autoincrement())
  name              String
  price             Decimal?           @db.Decimal(10, 2)
  stock             Int                @default(0)
  imageUrl          String?
  rating            Decimal?           @db.Decimal(3, 2)
  categoryId        Int?               @map("category_id")
  aiRecommendations AiRecommendation[]
  orderItems        OrderItem[]
  category          Category?          @relation(fields: [categoryId], references: [id])

  @@map("Products")
}

model Order {
  id          Int         @id @default(autoincrement())
  customerId  Int
  totalAmount Decimal?    @db.Decimal(10, 2)
  orderDate   DateTime    @default(now())
  status      String      @default("completada")
  salesUserId String?
  orderItems  OrderItem[]
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesUser   Profile?    @relation(fields: [salesUserId], references: [id])

  @@map("Orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int?
  quantity  Int
  unitPrice Decimal? @db.Decimal(10, 2)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])

  @@map("OrderItem")
}

model Opportunity {
  id             Int      @id @default(autoincrement())
  customerId     Int
  assignedUserId String?
  estimatedValue Decimal? @db.Decimal(10, 2)
  stage          Stage    @default(nueva)
  priority       Priority @default(Media)
  createdAt      DateTime @default(now())
  notes          String?
  assignedUser   Profile? @relation(fields: [assignedUserId], references: [id])
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("Opportunity")
}

model AiRecommendation {
  id                   Int      @id @default(autoincrement())
  customerId           Int
  recommendedProductId Int?
  score                Decimal? @db.Decimal(5, 2)
  recommendationText   String?
  nextAction           String?
  generatedAt          DateTime @default(now())
  customer             Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recommendedProduct   Product? @relation(fields: [recommendedProductId], references: [id])

  @@map("AiRecommendation")
}

enum Role {
  admin
  vendedor
  gerente
}

enum Stage {
  nueva
  seguimiento
  propuesta_enviada
  cerrada_ganada
  cerrada_perdida
}

enum Priority {
  Alta
  Media
  Baja
}
